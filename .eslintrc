{
  "env": {
    "browser": true,
    "node": true,
    "es2024": true,
    "mocha": true
  },
  "extends": [
    "recomended",
    "google"
  ],
  "parserOptions": {
    "sourceType": "module"
  },
  "plugins": [
    "eslint-plugin-lit",
    "sql"
  ],
  "rules": {
    "sql/format": [
      2,
      {
        "ignoreExpressions": false,
        "ignoreInline": true,
        "ignoreTagless": true
      }
    ],
    "sql/no-unsafe-query": [
      2,
      {
        "allowLiteral": false
      }
    ]
  }
}
